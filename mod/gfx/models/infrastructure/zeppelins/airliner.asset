pdxmesh = {
	name = "airliner_mesh"
	file = "airliner.mesh"

	lod_percentages = {
		lod = { index = 1 percent = 12.0 }
		lod = { index = 2 percent = 6.0 }
	}

	meshsettings = {
		name = "commercial_jet"
		index = 0
		texture_diffuse = "airliner_diffuse.dds"
		texture_normal = "airliner_normal.dds"
		texture_specular = "airliner_properties.dds"
		shader = "standard"
		shader_file = "gfx/FX/pdxmesh.shader"
	}
}

entity = {
    name = "airliner_entity"
    pdxmesh = "airliner_mesh"
    default_state = "moving"
	locator = { name = "loc_light" position = { 0 0.87 -0.6 } rotation = { 0 0 0 }}

    state = {
        name = "moving"
        next_state = "moving"

        start_event = { sound  = { soundeffect = "event:/SFX/Vehicles/zeppelin" } keep_sound = yes }
    }
    scale = 0.14
}