				io_ngo_card = {
					blockoverride "ngo_icon" { texture = "gfx/interface/icons/organization_icons/nongovernmental/iaea.dds" }
					blockoverride "ngo_name" { text = "io_iaea_name" }
					blockoverride "ngo_desc" { text = "io_iaea_desc" }
					blockoverride "ngo_opinion_val" { raw_text = "[GetPlayer.MakeScope.Var('io_ngo_iaea_opinion').GetValue|0]" }
					blockoverride "ngo_status_content" {
						textbox = { visible = "[GetPlayer.MakeScope.Var('io_ngo_iaea_banned').IsSet]" raw_text = "#n Banned#!" autoresize = yes using = fontsize_small }
						textbox = { visible = "[GetPlayer.MakeScope.Var('io_ngo_iaea_supported').IsSet]" raw_text = "#p Supported#!" autoresize = yes using = fontsize_small }
						textbox = { visible = "[And(Not(GetPlayer.MakeScope.Var('io_ngo_iaea_banned').IsSet), Not(GetPlayer.MakeScope.Var('io_ngo_iaea_supported').IsSet))]" raw_text = "#v Active#!" autoresize = yes using = fontsize_small }
					}
					blockoverride "ngo_ban" { onclick = "[GetScriptedGui('io_ngo_ban_iaea').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_ngo_ban_iaea').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
