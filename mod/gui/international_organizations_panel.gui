	### ══════════════════════════════════════
	### TEMPLATE: NGO Card
	### ══════════════════════════════════════
	type io_ngo_card = flowcontainer {
		direction = vertical
		parentanchor = hcenter
		minimumsize = { @panel_width_plus_14 -1 }
		margin_bottom = 8

		widget = {
			size = { @panel_width_plus_14 -1 }
			parentanchor = hcenter
			background = { using = entry_bg_simple }

			flowcontainer = {
				direction = vertical
				minimumsize = { @panel_width -1 }
				margin = { 12 10 }
				spacing = 8
				resizeparent = yes

				# Header row
				flowcontainer = {
					layoutpolicy_horizontal = expanding
					spacing = 10

					icon = {
						size = { 40 40 }
						block "ngo_icon" { texture = "gfx/interface/icons/generic_icons/diplomatic_action.dds" }
					}

					flowcontainer = {
						direction = vertical
						parentanchor = vcenter
						minimumsize = { 310 -1 }
						maximumsize = { 310 -1 }
						textbox = {
							minimumsize = { 310 -1 }
							maximumsize = { 310 -1 }
							block "ngo_name" { text = "" }
							autoresize = yes
							multiline = yes
							align = left|nobaseline
							using = fontsize_large
							default_format = "#header"
						}
					}

					flowcontainer = {
						direction = vertical
						parentanchor = vcenter
						textbox = { text = "io_ngo_opinion_label" autoresize = yes align = right|nobaseline using = fontsize_small }
						textbox = { block "ngo_opinion_val" { raw_text = "50" } autoresize = yes align = right|nobaseline using = fontsize_large default_format = "#v" }
					}
				}

				flowcontainer = {
					block "ngo_status_content" {}
				}

				divider_clean = { minimumsize = { 530 2 } }

				textbox = {
					block "ngo_desc" { text = "" }
					minimumsize = { 530 -1 }
					maximumsize = { 530 -1 }
					autoresize = yes
					multiline = yes
					align = left|nobaseline
					using = fontsize_small
				}

				flowcontainer = {
					spacing = 5
					button = { using = default_button text = "io_ban_button" size = { 165 30 } block "ngo_ban" {} }
					button = { using = default_button text = "io_unban_button" size = { 165 30 } block "ngo_unban" {} }
					button = { using = default_button text = "io_support_button" size = { 165 30 } block "ngo_support" {} }
				}
			}
		}
	}

	### ══════════════════════════════════════
	### TEMPLATE: Modifier Entry
	### ══════════════════════════════════════
	type io_modifier_entry = widget {
		size = { @panel_width_plus_14 25 }
		parentanchor = hcenter
		background = { using = entry_bg }
		textbox = {
			size = { 530 25 }
			block "mod_text" { raw_text = "" }
			position = { 15 0 }
			parentanchor = vcenter
			autoresize = yes
			align = left|nobaseline
			using = fontsize_small
		}
	}
}
