﻿530 = 530
@panel_width = 540
@panel_width_half = 270
@panel_width_plus_10 = 550
@panel_width_plus_14 = 554
@panel_width_plus_14_half = 277
@panel_width_plus_20 = 560
@panel_width_plus_30 = 570

types io_panel_types {

	type io_panel = default_block_window {
		name = "io_panel"
		datacontext = "[GetMetaPlayer.GetPlayedOrObservedCountry]"
		visible = "[GetVariableSystem.HasValue('com_open_window', 'io_sidebar_button')]"
		using = hud_visibility
		# Community Mod Framework panels do not inherit the vanilla InformationPanelBar placement,
		# so keep explicit sidebar geometry while still using default_block_window internals.
		parentanchor = top|left
		position = { 0 80 }
		size = { @panel_width_plus_20 100% }
		allow_outside = yes
		alwaystransparent = no

		blockoverride "animation_state_block" {
			state = {
				name = _show
			}
			state = {
				name = _hide
			}
		}

		blockoverride "window_header_name" {
			text = "io_panel_title"
		}

		blockoverride "header_close_button" {
			onclick = "[GetVariableSystem.Clear('com_open_window')]"
			shortcut = "close_window"
		}

		blockoverride "entire_back_button" {
			back_button_large = {
				position = { 8 30 }
				onclick = "[GetVariableSystem.Clear('io_viewing_org')]"
				visible = "[GetVariableSystem.Exists('io_viewing_org')]"
				input_action = "back"
			}

			back_button_large = {
				position = { 8 30 }
				onclick = "[GetVariableSystem.Clear('com_open_window')]"
				visible = "[Not(GetVariableSystem.Exists('io_viewing_org'))]"
				input_action = "back"
			}
		}

		blockoverride "fixed_top" {
			# Default tab on create
			widget = {
				size = { 0 0 }
				state = {
					trigger_on_create = yes
					on_finish = "[GetVariableSystem.Set('io_tab', 'igos')]"
				}
			}

			top_illu = {
				blockoverride "illu" {
					texture = "gfx/interface/illustrations/top_illus/top_illu_budget.dds"
				}

				textbox = {
					parentanchor = center
					using = fontsize_xl
					autoresize = yes
					align = hcenter|nobaseline
					text = "io_panel_title"
				}
			}

			tab_buttons = {
				blockoverride "first_button" { text = "io_tab_igos_label" }
				blockoverride "first_button_tooltip" { tooltip = "io_tab_igos_label" }
				blockoverride "first_button_click" {
					onclick = "[GetVariableSystem.Set('io_tab', 'igos')]"
					onclick = "[GetVariableSystem.Clear('io_viewing_org')]"
				}
				blockoverride "first_button_visibility" { visible = "[Or(GetVariableSystem.HasValue('io_tab', 'igos'), Or(Not(GetVariableSystem.Exists('io_tab')), And(Not(GetVariableSystem.HasValue('io_tab', 'treaties')), Not(GetVariableSystem.HasValue('io_tab', 'ngos')))))]" }
				blockoverride "first_button_visibility_checked" { visible = "[And(Not(GetVariableSystem.HasValue('io_tab', 'igos')), GetVariableSystem.Exists('io_tab'))]" }
				blockoverride "first_button_selected" { text = "io_tab_igos_label" }

				blockoverride "second_button" { text = "io_tab_treaties_label" }
				blockoverride "second_button_tooltip" { tooltip = "io_tab_treaties_label" }
				blockoverride "second_button_click" {
					onclick = "[GetVariableSystem.Set('io_tab', 'treaties')]"
					onclick = "[GetVariableSystem.Clear('io_viewing_org')]"
				}
				blockoverride "second_button_visibility" { visible = "[GetVariableSystem.HasValue('io_tab', 'treaties')]" }
				blockoverride "second_button_visibility_checked" { visible = "[Not(GetVariableSystem.HasValue('io_tab', 'treaties'))]" }
				blockoverride "second_button_selected" { text = "io_tab_treaties_label" }

				blockoverride "third_button" { text = "io_tab_ngos_label" }
				blockoverride "third_button_tooltip" { tooltip = "io_tab_ngos_label" }
				blockoverride "third_button_click" {
					onclick = "[GetVariableSystem.Set('io_tab', 'ngos')]"
					onclick = "[GetVariableSystem.Clear('io_viewing_org')]"
				}
				blockoverride "third_button_visibility" { visible = "[GetVariableSystem.HasValue('io_tab', 'ngos')]" }
				blockoverride "third_button_visibility_checked" { visible = "[Not(GetVariableSystem.HasValue('io_tab', 'ngos'))]" }
				blockoverride "third_button_selected" { text = "io_tab_ngos_label" }
			}

			widget = { size = { 1 10 } }
		}

		blockoverride "scrollarea_content" {
			flowcontainer = {
				direction = vertical
				using = default_list_position
				using = default_content_fade
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				minimumsize = { @panel_width_plus_14 -1 }
				maximumsize = { @panel_width_plus_14 -1 }
				margin_bottom = 15

				### SCROLLAREA WIDTH/HEIGHT WRAPPER
			### ══════════════════════════════════
			###  ORGANIZATIONS TAB
			### ══════════════════════════════════
			flowcontainer = {
				visible = "[Or(GetVariableSystem.HasValue('io_tab', 'igos'), Or(Not(GetVariableSystem.Exists('io_tab')), And(Not(GetVariableSystem.HasValue('io_tab', 'treaties')), Not(GetVariableSystem.HasValue('io_tab', 'ngos')))))]"
				direction = vertical
				using = default_list_position
				margin_top = 5
				margin_bottom = 15

				### ── LIST VIEW ──
				flowcontainer = {
					visible = "[Not(GetVariableSystem.Exists('io_viewing_org'))]"
					direction = vertical
					using = default_list_position

					default_header_2texts = {
						blockoverride "text1" {
			text = "io_tab_igos_label"
						}
					}

					widget = {
						size = { @panel_width_plus_14 50 }
						parentanchor = hcenter
						textbox = {
			text = "io_igos_tab_desc"
			position = { 15 0 }
			parentanchor = vcenter
			size = { 530 50 }
			multiline = yes
			align = left|nobaseline
			using = fontsize_small
						}
					}

					widget = { size = { 5 5 } }
					divider_decorative = {}
					widget = { size = { 5 5 } }

					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_un_name" }
						blockoverride "io_entry_type" { text = "io_type_cooperative" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'un')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/united_nations.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_un').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_nato_name" }
						blockoverride "io_entry_type" { text = "io_type_military_defense" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'nato')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/nato.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_nato').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_g7_name" }
						blockoverride "io_entry_type" { text = "io_type_financial" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'g7')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/g7.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_g7').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_opec_name" }
						blockoverride "io_entry_type" { text = "io_type_free_trade" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'opec')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/opec.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_opec').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						visible = "[GetScriptedGui('io_join_eec').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
						blockoverride "io_entry_name" { text = "io_eec_name" }
						blockoverride "io_entry_type" { text = "io_type_free_trade" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'eec')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/european.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_eec').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						visible = "[GetScriptedGui('io_join_eu').IsShown(GuiScope.SetRoot(Country.MakeScope).End)]"
						blockoverride "io_entry_name" { text = "io_eu_name" }
						blockoverride "io_entry_type" { text = "io_type_free_trade" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'eu')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/european.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_eu').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_arab_league_name" }
						blockoverride "io_entry_type" { text = "io_type_cultural_pact" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'arab_league')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/arab_league.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_arab_league').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_imf_name" }
						blockoverride "io_entry_type" { text = "io_type_financial" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'imf')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/imf.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_imf').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
				#	io_org_list_item = {
				#		blockoverride "io_entry_name" { text = "io_esa_name" }
				#		blockoverride "io_entry_type" { text = "io_type_cooperative" }
				#		blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'esa')]" }
				#		blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/esa.dds" }
					#	blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_esa').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					#}
					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_asean_name" }
						blockoverride "io_entry_type" { text = "io_type_cooperative" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'asean')]" }
						blockoverride "io_entry_icon" { texture ="gfx/interface/icons/organization_icons/asean.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_asean').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_saarc_name" }
						blockoverride "io_entry_type" { text = "io_type_cooperative" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'saarc')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/saarc.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_saarc').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_cis_name" }
						blockoverride "io_entry_type" { text = "io_type_cooperative" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'cis')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/cis.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_cis').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
					io_org_list_item = {
						blockoverride "io_entry_name" { text = "io_who_name" }
						blockoverride "io_entry_type" { text = "io_type_cooperative" }
						blockoverride "io_entry_click" { onclick = "[GetVariableSystem.Set('io_viewing_org', 'who')]" }
						blockoverride "io_entry_icon" { texture = "gfx/interface/icons/organization_icons/who.dds" }
						blockoverride "io_entry_member" { visible = "[GetScriptedGui('io_leave_who').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" }
					}
				}

				### ── DETAIL VIEWS ──
				io_org_detail = {
					visible = "[GetVariableSystem.HasValue('io_viewing_org', 'un')]"
					blockoverride "detail_name" { text = "io_un_name" }
					blockoverride "detail_type_text" { text = "io_type_cooperative" }
					blockoverride "detail_type_tooltip" { tooltip = "concept_cooperative_agreement" }
					blockoverride "detail_desc" { text = "io_un_desc" }
					blockoverride "detail_icon" { texture = "gfx/interface/icons/organization_icons/united_nations.dds" }
					blockoverride "detail_modifier_content" {
						textbox = { raw_text = "#italic No direct modifiers. Influence exercised through resolutions.#!" parentanchor = hcenter autoresize = yes align = left|nobaseline using = fontsize_small margin = { 10 8 } }
					}
					blockoverride "detail_member_list" { datamodel = "[GetGlobalList('io_un_members')]" }
					blockoverride "detail_join" { onclick = "[GetScriptedGui('io_join_un').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_join_un').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_join_un').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
					blockoverride "detail_leave" { onclick = "[GetScriptedGui('io_leave_un').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_leave_un').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_leave_un').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
				}
				io_org_detail = {
					visible = "[GetVariableSystem.HasValue('io_viewing_org', 'nato')]"
					blockoverride "detail_name" { text = "io_nato_name" }
					blockoverride "detail_type_text" { text = "io_type_military_defense" }
					blockoverride "detail_type_tooltip" { tooltip = "concept_military_defense_agreement" }
					blockoverride "detail_desc" { text = "io_nato_desc" }
					blockoverride "detail_icon" { texture = "gfx/interface/icons/organization_icons/nato.dds" }
					blockoverride "detail_modifier_content" {
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_military_defense_pact" } }
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_prestige_2pct" } }
								}
					blockoverride "detail_member_list" { datamodel = "[GetGlobalList('io_nato_members')]" }
					blockoverride "detail_join" { onclick = "[GetScriptedGui('io_join_nato').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_join_nato').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_join_nato').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
					blockoverride "detail_leave" { onclick = "[GetScriptedGui('io_leave_nato').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_leave_nato').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_leave_nato').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
				}
				io_org_detail = {
					visible = "[GetVariableSystem.HasValue('io_viewing_org', 'g7')]"
					blockoverride "detail_name" { text = "io_g7_name" }
					blockoverride "detail_type_text" { text = "io_type_financial" }
					blockoverride "detail_type_tooltip" { tooltip = "concept_financial_agreement" }
					blockoverride "detail_desc" { text = "io_g7_desc" }
					blockoverride "detail_icon" { texture = "gfx/interface/icons/organization_icons/g7.dds" }
					blockoverride "detail_modifier_content" {
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_influence_5pct" } }
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_diplo_rep_1" } }
								}
					blockoverride "detail_member_list" { datamodel = "[GetGlobalList('io_g7_members')]" }
					blockoverride "detail_join" { onclick = "[GetScriptedGui('io_join_g7').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_join_g7').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_join_g7').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
					blockoverride "detail_leave" { onclick = "[GetScriptedGui('io_leave_g7').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_leave_g7').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_leave_g7').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
				}
				io_org_detail = {
					visible = "[GetVariableSystem.HasValue('io_viewing_org', 'opec')]"
					blockoverride "detail_name" { text = "io_opec_name" }
					blockoverride "detail_type_text" { text = "io_type_free_trade" }
					blockoverride "detail_type_tooltip" { tooltip = "concept_free_trade_agreement" }
					blockoverride "detail_desc" { text = "io_opec_desc" }
					blockoverride "detail_icon" { texture = "gfx/interface/icons/organization_icons/opec.dds" }
					blockoverride "detail_modifier_content" {
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_opec_trade_advantage" } }
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_opec_throughput" } }
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_opec_customs" } }
								}
					blockoverride "detail_member_list" { datamodel = "[GetGlobalList('io_opec_members')]" }
					blockoverride "detail_join" { onclick = "[GetScriptedGui('io_join_opec').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_join_opec').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_join_opec').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
					blockoverride "detail_leave" { onclick = "[GetScriptedGui('io_leave_opec').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_leave_opec').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_leave_opec').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
				}
				io_org_detail = {
					visible = "[And(GetVariableSystem.HasValue('io_viewing_org', 'eec'), GetScriptedGui('io_join_eec').IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"
					blockoverride "detail_name" { text = "io_eec_name" }
					blockoverride "detail_type_text" { text = "io_type_financial" }
					blockoverride "detail_type_tooltip" { tooltip = "concept_free_trade_agreement" }
					blockoverride "detail_desc" { text = "io_eec_desc" }
					blockoverride "detail_icon" { texture = "gfx/interface/icons/organization_icons/european.dds" }
					blockoverride "detail_modifier_content" {
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_eec_customs" } }
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_free_trade_convoys" } }
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_free_trade_expedition" } }
								}
					blockoverride "detail_member_list" { datamodel = "[GetGlobalList('io_eec_members')]" }
					blockoverride "detail_join" { onclick = "[GetScriptedGui('io_join_eec').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_join_eec').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_join_eec').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
					blockoverride "detail_leave" { onclick = "[GetScriptedGui('io_leave_eec').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_leave_eec').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_leave_eec').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
				}
				io_org_detail = {
					visible = "[And(GetVariableSystem.HasValue('io_viewing_org', 'eu'), GetScriptedGui('io_join_eu').IsShown(GuiScope.SetRoot(Country.MakeScope).End))]"
					blockoverride "detail_name" { text = "io_eu_name" }
					blockoverride "detail_type_text" { text = "io_type_free_trade" }
					blockoverride "detail_type_tooltip" { tooltip = "concept_free_trade_agreement" }
					blockoverride "detail_desc" { text = "io_eu_desc" }
					blockoverride "detail_icon" { texture = "gfx/interface/icons/organization_icons/european.dds" }
					blockoverride "detail_modifier_content" {
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_eec_customs" } }
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_free_trade_convoys" } }
									io_modifier_entry = { blockoverride "mod_text" { text = "io_mod_free_trade_expedition" } }
								}
					blockoverride "detail_member_list" { datamodel = "[GetGlobalList('io_eu_members')]" }
					blockoverride "detail_join" { onclick = "[GetScriptedGui('io_join_eu').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_join_eu').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_join_eu').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
					blockoverride "detail_leave" { onclick = "[GetScriptedGui('io_leave_eu').Execute(GuiScope.SetRoot(Country.MakeScope).End)]" enabled = "[GetScriptedGui('io_leave_eu').IsValid(GuiScope.SetRoot(Country.MakeScope).End)]" tooltip = "[GetScriptedGui('io_leave_eu').BuildTooltip(GuiScope.SetRoot(GetPlayer.MakeScope).End)]" }
				}
				io_org_detail = {
					visible = "[GetVariableSystem.HasValue('io_viewing_org', 'arab_league')]"
					blockoverride "detail_name" { text = "io_arab_league_name" }
					blockoverride "detail_type_text" { text = "io_type_cultural_pact" }
					blockoverride "detail_type_tooltip" { tooltip = "concept_cultural_pact" }
					blockoverride "detail_desc" { text = "io_arab_league_desc" }
					blockoverride "detail_icon" { texture = "gfx/interface/icons/organization_icons/arab_league.dds" }
