	### ══════════════════════════════════════
	### TEMPLATE: Organization List Item
	### ══════════════════════════════════════
	type io_org_list_item = widget {
		size = { @panel_width_plus_14 50 }
		parentanchor = hcenter

		button = {
			using = default_button
			size = { 100% 100% }
			block "io_entry_click" {}

			hbox = {
				margin = { 10 5 }
				spacing = 10

				icon = {
					size = { 36 36 }
					block "io_entry_icon" { texture = "gfx/interface/icons/generic_icons/truce.dds" }
				}

				vbox = {
					layoutpolicy_horizontal = expanding
					spacing = 2

					textbox = {
						block "io_entry_name" { text = "" }
						layoutpolicy_horizontal = expanding
						autoresize = yes
						align = left|nobaseline
						using = fontsize_large
						default_format = "#header"
					}
					textbox = {
						block "io_entry_type" { text = "" }
						layoutpolicy_horizontal = expanding
						autoresize = yes
						align = left|nobaseline
						using = fontsize_small
					}
				}

				icon = {
					size = { 36 36 }
					texture = "gfx/interface/icons/generic_icons/leading_interest_group_icon.dds"
					block "io_entry_member" { visible = no }
					tooltip = "io_member_indicator_tt"
				}
			}
		}
	}

	### ══════════════════════════════════════
	### TEMPLATE: Organization Detail View
	### ══════════════════════════════════════
	type io_org_detail = flowcontainer {
		direction = vertical
		using = default_list_position
		margin_bottom = 10

		# Back button
		flowcontainer = {
			margin_bottom = 5
			parentanchor = hcenter
			minimumsize = { @panel_width -1 }
			button = {
				using = default_button
				size = { 120 30 }
				text = "io_back_button"
				onclick = "[GetVariableSystem.Clear('io_viewing_org')]"
			}
		}

		# Header with icon
		widget = {
			size = { @panel_width_plus_14 100 }
			parentanchor = hcenter
			background = { using = entry_bg_simple }

			hbox = {
				layoutpolicy_horizontal = expanding
				margin = { 15 10 }
				spacing = 15

				icon = {
					size = { 56 56 }
					block "detail_icon" { texture = "gfx/interface/icons/generic_icons/diplomatic_action.dds" }
				}

				vbox = {
					layoutpolicy_horizontal = expanding
					minimumsize = { 420 -1 }
					maximumsize = { 420 -1 }
					spacing = 4

					textbox = {
						minimumsize = { 420 -1 }
						maximumsize = { 420 -1 }
						block "detail_name" { text = "" }
						layoutpolicy_horizontal = expanding
						autoresize = yes
						multiline = yes
						align = left|nobaseline
						using = header_font
						using = fontsize_xl
						default_format = "#header"
					}

					textbox = {
						minimumsize = { 420 -1 }
						maximumsize = { 420 -1 }
						block "detail_type_text" { text = "" }
						block "detail_type_tooltip" {}
						autoresize = yes
						align = left|nobaseline
						using = fontsize_small
					}
				}
			}
		}

		widget = { size = { 5 5 } }

		# Description
		widget = {
			size = { @panel_width_plus_14 -1 }
			parentanchor = hcenter
			flowcontainer = {
				direction = vertical
				minimumsize = { @panel_width -1 }
				margin = { 15 10 }
				resizeparent = yes
				textbox = {
					block "detail_desc" { text = "" }
					minimumsize = { 530 -1 }
					maximumsize = { 530 -1 }
					autoresize = yes
					multiline = yes
					align = left|nobaseline
				}
			}
		}

		widget = { size = { 5 3 } }
		divider_decorative = {}
		widget = { size = { 5 3 } }

		# Modifiers section
		flowcontainer = {
			direction = vertical
			parentanchor = hcenter
			default_header_2texts = {
				blockoverride "text1" { text = "io_modifiers_header" }
			}
			flowcontainer = {
				direction = vertical
				parentanchor = hcenter
				minimumsize = { @panel_width -1 }
				margin = { 5 0 }
				block "detail_modifier_content" {}
			}
		}

		widget = { size = { 5 3 } }
		divider_decorative = {}
		widget = { size = { 5 3 } }

		# Action buttons
		flowcontainer = {
			parentanchor = hcenter
			spacing = 10
			margin = { 10 5 }

			button = {
				using = default_button
				text = "io_request_join_button"
				size = { 245 35 }
				block "detail_join" {}
			}
			button = {
				using = default_button
				text = "io_leave_button"
				size = { 245 35 }
				block "detail_leave" {}
			}
		}

		widget = { size = { 5 3 } }
		divider_decorative = {}
		widget = { size = { 5 3 } }

		# Member Countries List (like nuclear state targeting list)
		flowcontainer = {
			direction = vertical
			parentanchor = hcenter

			default_header_2texts = {
				blockoverride "text1" { text = "io_members_header" }
			}

			scrollbox = {
				parentanchor = hcenter
				size = { @panel_width_plus_14 250 }

				blockoverride "scrollbox_content" {
					vbox = {
						layoutpolicy_horizontal = expanding
						spacing = 1
						datamodel_wrap = 1
						block "detail_member_list" {
							datamodel = "[GetGlobalList('io_un_members')]"
						}
						item = {
							widget = {
								layoutpolicy_horizontal = expanding
								size = { 0 26 }
								datacontext = "[Scope.AccessCountry]"

								background = {
									using = entry_bg
								}

								hbox = {
									layoutpolicy_horizontal = expanding
									margin = { 8 2 }
									spacing = 8

									icon = {
										size = { 24 16 }
										texture = "[Country.GetFlag]"
										parentanchor = vcenter
									}

									textbox = {
										layoutpolicy_horizontal = expanding
										autoresize = yes
										align = left|nobaseline
										raw_text = "[Country.GetName]"
										using = fontsize_small
									}
								}
							}
						}
					}
				}
			}
		}
	}

	### ══════════════════════════════════════
	### TEMPLATE: Treaty List Item
	### ══════════════════════════════════════
	type io_treaty_list_item = widget {
		size = { @panel_width_plus_14 42 }
		parentanchor = hcenter

		button = {
			using = default_button
			size = { 100% 100% }
			block "treaty_click" {}

			hbox = {
				layoutpolicy_horizontal = expanding
				margin = { 10 5 }
				spacing = 100

				icon = {
					size = { 36 36 }
					texture = "gfx/interface/icons/organization_icons/treaty.dds"
				}

				textbox = {
					minimumsize = { 450 -1 }
					maximumsize = { 450 -1 }
					block "treaty_name" { text = "" }
					layoutpolicy_horizontal = expanding
					autoresize = yes
					align = left|nobaseline
					using = fontsize_large
					default_format = "#header"
				}

				icon = {
					size = { 28 28 }
					texture = "gfx/interface/icons/generic_icons/legitimacy.dds"
					block "treaty_signed" { visible = no }
					tooltip = "io_treaty_signed_tt"
				}
			}
		}
	}

